# Application
APP_NAME=PolicySight
APP_ENV=development
APP_SECRET=change-me-in-production
DEBUG=true

# Database (TimescaleDB — PostgreSQL + time-series extension)
DATABASE_URL=postgresql://policysight:policysight@localhost:6543/policysight
DB_HOST=localhost
DB_PORT=6543
DB_USER=policysight
DB_PASSWORD=policysight
DB_NAME=policysight
# TimescaleDB is pre-loaded — no extension loading needed in app code.
# To create hypertables: SELECT create_hypertable('table_name', 'time_column');
# Full analysis: docs/TIMESCALEDB_COST_BENEFIT_ANALYSIS.md

# AI / LLM
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Frontend
VITE_API_URL=http://localhost:8000/api

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Stripe (placeholder)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
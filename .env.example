# Application
APP_NAME=PolicySight
APP_ENV=development
APP_SECRET=change-me-in-production
DEBUG=true

# Database
DATABASE_URL=postgresql://policysight:policysight@localhost:5432/policysight
DB_HOST=localhost
DB_PORT=5432
DB_USER=policysight
DB_PASSWORD=policysight
DB_NAME=policysight

# AI / LLM
# OPENAI_API_KEY=sk-...           # Use with OpenAI
# OPENAI_BASE_URL=               # Empty = default OpenAI; "https://api.groq.com/openai/v1" for Groq
# OPENAI_MODEL=gpt-4o-mini       # Use "llama-3.3-70b-versatile" for Groq

# Groq (free, OpenAI-compatible) — uncomment and use instead of OpenAI:
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Frontend
VITE_API_URL=http://localhost:8000

# Stripe (placeholder)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder